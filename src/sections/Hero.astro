---
import { TRACKS } from '@lib/tracks';

const musicCount = TRACKS.filter(t => t.category === 'music').length;
const productionsCount = TRACKS.filter(t => t.category === 'productions').length;
const sessionsCount = TRACKS.filter(t => t.category === 'sessions').length;
const starredCount = TRACKS.filter(t => t.star).length;

const stats = [
    { count: musicCount, label: 'MUSIC' },
    { count: sessionsCount, label: 'SESSIONS' },
    { count: productionsCount, label: 'PRODUCTIONS' },
    { accent: true, count: starredCount, label: 'STARRED' },
];
---

<section
    class="hero px-[clamp(1rem,calc(0.5rem+2.5vw),2.5rem)] py-[clamp(5rem,calc(3rem+10vw),12rem)] border-b border-zinc-800"
>
    <div class="max-w-[80rem] mx-auto">
        <h1 class="hero__title mb-[clamp(2rem,calc(1.33rem+3.33vw),4rem)] font-semibold text-[clamp(4rem,calc(2.33rem+8.33vw),9rem)] tracking-[-0.045em] leading-none font-inter text-zinc-100">
            aephonics
            <br />
            <span class="text-zinc-400">from concept</span>
            <br />
            <span class="text-[var(--color-orange-80)]">to master.</span>
        </h1>
        <p class="hero__subtitle max-w-[49rem] text-[clamp(1rem,calc(0.83rem+0.83vw),1.5rem)] leading-relaxed font-inter text-zinc-300">
            Frequencies shaped in a room in Austin since 2015. Original compositions, late-night sessions, ghost productions — moving between hip-hop, latin pop, ambient, and territories that resist classification.
        </p>
        <div
            class="grid grid-cols-2 gap-[clamp(1rem,calc(0.67rem+1.67vw),2rem)] mt-[clamp(3rem,calc(2rem+5vw),6rem)] p-[clamp(1rem,calc(0.75rem+1.25vw),1.75rem)] border border-zinc-800 bg-zinc-800 md:grid-cols-4"
        >
            {stats.map(({ accent, count, label }, i) => (
                <div class={`${i ? 'border-l-2 border-zinc-700' : ''} pl-[clamp(0.75rem,calc(0.63rem+0.62vw),1.125rem)] text-center`}>
                    <div class="mb-2.5 text-[0.6875rem] tracking-[0.22em] text-zinc-400">{label}</div>
                    <div class:list={['hero__stat-count font-medium text-[clamp(1.5rem,calc(1.17rem+1.67vw),2.5rem)] tracking-[-0.025em] leading-none font-inter', accent ? 'text-[var(--color-orange-80)]' : 'text-zinc-100']}>
                        {count}
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
