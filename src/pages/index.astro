---
import { getCollection } from 'astro:content';

import Catalog from '@sections/Catalog';
import Hero from '@sections/Hero.astro';
import Layout from '@/Layout.astro';
import Player from '@sections/Player';

const entries = await getCollection('tracks');
const tracks = entries
    .map(entry => ({ ...entry.data, id: entry.id }))
    .sort((a, b) => a.id.localeCompare(b.id));
const catalogTracks = tracks.map(track => ({
    audioUrl: track.audioUrl,
    category: track.category,
    data: track.data,
    flags: track.flags,
    id: track.id,
    peaks: [] as number[],
    slug: track.slug,
}));
---

<Layout
    description="Browse original music, sessions, and productions from Aephonics."
    title="Music"
>
    <Player client:only="react" tracks={tracks} />
    <Hero tracks={tracks} />
    <Catalog client:load tracks={catalogTracks} />
</Layout>
