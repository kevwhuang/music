---
import '@fontsource/geist-sans/index.css';
import '@fontsource/ibm-plex-mono/300.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '@fontsource/ibm-plex-mono/600.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
    description: string;
    title: string;
}

const { description, title } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta content="width=device-width, initial-scale=1" name="viewport" />
        <title>{title}</title>
        <meta content="Kevin Huang" name="author" />
        <meta content={description} name="description" />
        <meta content="#09090b" name="theme-color" />
        <link href={canonicalUrl} rel="canonical" />
        <link href="/favicon.svg" rel="icon" type="image/svg+xml" />
        <meta content={title} property="og:title" />
        <meta content={description} property="og:description" />
        <meta content={canonicalUrl} property="og:url" />
        <meta content="website" property="og:type" />
        <meta content={`${Astro.site}og.png`} property="og:image" />
        <meta content="Music" property="og:site_name" />
        <meta content="summary_large_image" name="twitter:card" />
        <meta content={title} name="twitter:title" />
        <meta content={description} name="twitter:description" />
        <meta content={`${Astro.site}og.png`} name="twitter:image" />
        <script
            set:html={JSON.stringify({
                '@context': 'https://schema.org',
                '@type': 'WebSite',
                'founder': {
                    '@type': 'Person',
                    'name': 'Kevin Huang',
                },
                'name': 'Music',
                'url': Astro.site,
            })}
            type="application/ld+json"
        />
        <ClientRouter />
    </head>
    <body class="flex flex-col min-h-screen font-sans bg-zinc-950 text-white">
        <main class="flex-1">
            <slot />
        </main>
    </body>
</html>

<style is:global>
    @import 'tailwindcss';

    :root {
        --color-pink: 236, 72, 153;
        --font-sans: 'Geist', system-ui, sans-serif;
        --rgb-white: 255, 255, 255;

        --cn-bg: #1c1d20;
        --cn-bg2: #16171a;
        --cn-panel: #23252a;
        --cn-panel2: #2c2f35;
        --cn-border: #0e0f11;
        --cn-border2: #34373e;
        --cn-line: #262930;
        --cn-text: #ecebe6;
        --cn-text2: #c8c5bd;
        --cn-dim: #8a8d94;
        --cn-dim2: #5a5d65;

        --cn-pBg: #13110e;
        --cn-pBg2: #1a1814;
        --cn-pBorder: #26221b;
        --cn-pBorder2: #36312a;
        --cn-pText: #ecdfc4;
        --cn-pDim: #8c8170;
        --cn-pDim2: #5a5447;

        --cn-accent: #c97a4a;
        --cn-accent2: #a86138;
        --cn-accentDim: #5e3a25;
        --cn-sage: #8aa67c;
        --cn-sageDim: #4f6646;
        --cn-danger: #c4564b;
        --cn-star: #d8b15a;
        --cn-heart: #c97a8a;

        --cn-font: 'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, monospace;
        --cn-sans: 'Inter', -apple-system, system-ui, sans-serif;
    }

    :focus {
        outline: none;
    }

    :focus-visible {
        border-radius: 2px;
        outline: 2px solid rgba(var(--color-pink), 0.8);
        outline-offset: 2px;
    }

    @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
            animation-duration: 0.01ms !important;
            animation-iteration-count: 1 !important;
            scroll-behavior: auto !important;
            transition-duration: 0.01ms !important;
        }
    }
</style>
