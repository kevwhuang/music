---
const { tracks } = Astro.props;

const musicCount = tracks.filter(t => t.category === 'music').length;
const productionsCount = tracks.filter(t => t.category === 'productions').length;
const sessionsCount = tracks.filter(t => t.category === 'sessions').length;
const starredCount = tracks.filter(t => t.star).length;

const stats = [
    { count: musicCount, label: 'MUSIC' },
    { count: sessionsCount, label: 'SESSIONS' },
    { count: productionsCount, label: 'PRODUCTIONS' },
    { accent: true, count: starredCount, label: 'STARRED' },
];
---

<section
    class="hero px-10 py-48 border-b border-zinc-800"
>
    <div class="max-w-[80rem] mx-auto">
        <h1 class="hero__title mb-16 font-semibold text-9xl tracking-[-0.045em] leading-none font-inter text-zinc-100">
            aephonics
            <br />
            <span class="text-zinc-400">from concept</span>
            <br />
            <span class="text-[var(--color-orange-80)]">to master.</span>
        </h1>
        <p class="hero__subtitle max-w-[49rem] text-2xl leading-relaxed font-inter text-zinc-300">
            Frequencies shaped in a room in Austin since 2015. Original compositions, late-night sessions, ghost productions — moving between hip-hop, latin pop, ambient, and territories that resist classification.
        </p>
        <div
            class="grid grid-cols-4 gap-8 mt-24 p-7 border border-zinc-800 bg-zinc-800"
        >
            {stats.map(({ accent, count, label }, i) => (
                <div class={`${i ? 'border-l-2 border-zinc-700' : ''} pl-[1.125rem] text-center`}>
                    <div class="mb-2.5 text-[0.6875rem] tracking-[0.22em] text-zinc-400">{label}</div>
                    <div class:list={['hero__stat-count font-medium text-[2.5rem] tracking-[-0.025em] leading-none font-inter', accent ? 'text-[var(--color-orange-80)]' : 'text-zinc-100']}>
                        {count}
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
