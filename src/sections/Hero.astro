---
interface Props {
    tracks: Track[];
}

const { tracks } = Astro.props;

const TICKER = ['ideate', 'sample', 'synthesize', 'record', 'compose', 'arrange', 'produce', 'mix', 'master', 'publish'];

const stats = [
    { count: tracks.filter(track => track.category === 'music').length, label: 'MUSIC' },
    { count: tracks.filter(track => track.category === 'sessions').length, label: 'SESSIONS' },
    { count: tracks.filter(track => track.category === 'productions').length, label: 'PRODUCTIONS' },
    { accent: true, count: tracks.filter(track => track.flags.star).length, label: 'STARRED' },
];
---

<section
    class="hero py-32 border-b border-zinc-800"
    aria-label="Introduction"
>
    <div class="max-w-7xl mx-auto">
        <h1
            class="hero__title mb-12 font-inter font-semibold leading-none text-9xl tracking-[-0.05em] text-zinc-100"
            aria-label="Aephonics from concept to master"
        >
            <span
                class="hero__line opacity-0"
                aria-hidden="true"
            >
                aephonics
            </span>
            <br />
            <span
                class="hero__line text-zinc-400 opacity-0"
                aria-hidden="true"
            >
                from concept
            </span>
            <br />
            <span
                class="hero__line text-orange-80 opacity-0"
                aria-hidden="true"
            >
                to master.
            </span>
        </h1>
        <p class="hero__tagline mb-20 font-mono leading-relaxed text-xl tracking-[0.2em] uppercase text-zinc-300 opacity-0">
            Producer and engineer. A decade of craft. <span class="text-orange-80">5M+ streams.</span>
            <br />
            Minimal setup. Maximum signal. Untethered from genre.
            <br />
            Based in <span class="text-orange-80">Austin.</span> Open to collab.
        </p>
        <div class="hero__stats relative opacity-0">
            <div
                class="hero__ticker -top-9 absolute grid justify-items-end overflow-hidden right-6 h-7 w-fit"
                aria-hidden="true"
            >
                {TICKER.map(word => (
                    <span class="hero__ticker-word col-start-1 row-start-1 font-mono text-base tracking-[0.2em] text-zinc-500 opacity-0">{word}</span>
                ))}
            </div>
            <dl class="grid grid-cols-4 gap-8 p-6 border border-zinc-800 bg-zinc-800">
                {stats.map(({ accent, count, label }, i) => (
                    <div class={`pl-5 ${i ? 'border-l-2 border-zinc-700' : ''} text-center`}>
                        <dt class="mb-2 font-mono text-xs tracking-[0.2em] text-zinc-400">{label}</dt>
                        <dd class:list={['hero__stat-count font-inter font-medium leading-none text-4xl tracking-[-0.025em]', accent ? 'text-orange-80' : 'text-zinc-100']}>{count}</dd>
                    </div>
                ))}
            </dl>
        </div>
    </div>
</section>

<script>
    import gsap from 'gsap';

    const CHAR_DURATION = 0.5;
    const CHAR_STAGGER = 0.1;
    const CHAR_Y = 20;
    const HOLD = 2;
    const LINE_DURATION = 0.5;
    const LINE_Y = 30;
    const SECTION_DURATION = 0.5;
    const SECTION_Y = 30;
    const SLIDE = 0.5;
    const TIMELINE_DELAY = 1;

    function cycle(distance: number, words: NodeListOf<HTMLElement>): void {
        const timeline = gsap.timeline({ onComplete: () => cycle(distance, words) });

        timeline.fromTo(words[0], { x: distance }, { duration: SLIDE, ease: 'power2.out', x: 0 });

        for (let i = 0; i < words.length - 1; i++) {
            timeline.to(words[i], { duration: SLIDE, ease: 'power2.inOut', x: -distance }, `+=${HOLD}`);
            timeline.fromTo(words[i + 1], { x: distance }, { duration: SLIDE, ease: 'power2.inOut', x: 0 }, '<');
        }

        timeline.to(words[words.length - 1], { duration: SLIDE, ease: 'power2.in', x: -distance }, `+=${HOLD}`);
    }

    function initHero(): void {
        const lines = document.querySelectorAll<HTMLElement>('.hero__line');
        const stats = document.querySelector<HTMLElement>('.hero__stats');
        const tagline = document.querySelector<HTMLElement>('.hero__tagline');
        const ticker = document.querySelector<HTMLElement>('.hero__ticker');
        const words = document.querySelectorAll<HTMLElement>('.hero__ticker-word');

        if (!lines.length || !stats || !tagline || !ticker || !words.length) return;

        const distance = ticker.offsetWidth;

        gsap.set(words, { opacity: 1, x: distance });

        const skipEntrance = window.scrollY > 0
            || window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        if (skipEntrance) {
            lines.forEach(line => gsap.set(line, { opacity: 1 }));
            gsap.set(stats, { opacity: 1 });
            gsap.set(tagline, { opacity: 1 });
            cycle(distance, words);
            return;
        }

        const chars = splitChars(lines[0]);
        const timeline = gsap.timeline({ delay: TIMELINE_DELAY });

        gsap.set(lines[1], { y: LINE_Y });
        gsap.set(lines[2], { y: LINE_Y });
        gsap.set(stats, { y: SECTION_Y });
        gsap.set(tagline, { y: SECTION_Y });

        timeline.to(chars, {
            duration: CHAR_DURATION,
            ease: 'power3.out',
            opacity: 1,
            stagger: CHAR_STAGGER,
            y: 0,
        });
        timeline.to(lines[1], {
            duration: LINE_DURATION,
            ease: 'power3.out',
            opacity: 1,
            y: 0,
        });
        timeline.to(lines[2], {
            duration: LINE_DURATION,
            ease: 'power3.out',
            opacity: 1,
            y: 0,
        });
        timeline.to(tagline, {
            duration: SECTION_DURATION,
            ease: 'power3.out',
            opacity: 1,
            y: 0,
        });
        timeline.to(stats, {
            duration: SECTION_DURATION,
            ease: 'power3.out',
            opacity: 1,
            y: 0,
        });
        timeline.call(() => cycle(distance, words), undefined, '<');
    }

    function splitChars(element: HTMLElement): HTMLElement[] {
        const chars: HTMLElement[] = [];
        const text = element.textContent || '';

        element.textContent = '';
        gsap.set(element, { opacity: 1 });

        for (const char of text) {
            if (char === ' ') {
                element.appendChild(document.createTextNode(' '));
                continue;
            }

            const span = document.createElement('span');

            span.textContent = char;
            element.appendChild(span);
            chars.push(span);
        }

        gsap.set(chars, { display: 'inline-block', opacity: 0, y: CHAR_Y });

        return chars;
    }

    document.addEventListener('astro:page-load', initHero);
</script>
